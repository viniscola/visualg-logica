algoritmo "Imposto_Importacao"

var
  valor: real
  imposto: real

inicio

  escreval("Digite o valor do produto em dolares: ")
  leia(valor)

  se (valor > 50) entao
    imposto <- valor * 0.60

  senao
    imposto <- valor * 0.17

  fimse

  escreval("Valor do imposto: $ ", imposto:0:2)

fimalgoritmo